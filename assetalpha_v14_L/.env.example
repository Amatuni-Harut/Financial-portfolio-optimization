# ============================================================
# AssetAlpha v14.0 — Шаблон конфигурации
# Скопируйте в .env и заполните своими значениями
# НИКОГДА не коммитьте .env в git!
# ============================================================

# Строка подключения к PostgreSQL (sync psycopg2 — НЕ asyncpg)
# Формат: postgresql://ПОЛЬЗОВАТЕЛЬ:ПАРОЛЬ@ХОСТ:ПОРТ/ИМЯ_БД
DB_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/assetalpha

# Секретный ключ JWT — ОБЯЗАТЕЛЬНЫЙ, минимум 32 символа
# Генерация: python -c "import secrets; print(secrets.token_hex(32))"
# Приложение НЕ запустится без этого ключа или с коротким значением
SECRET_KEY=СГЕНЕРИРУЙТЕ_КЛЮЧ_КОМАНДОЙ_ВЫШЕ_И_ВСТАВЬТЕ_СЮДА

# Время жизни токена в минутах
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS origins (через запятую или JSON-массив)
CORS_ORIGINS=http://localhost:8000

# TTL кэша в часах
CACHE_TTL_HOURS=4

# Уровень логирования: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Rate limiting: макс. запросов к /login и /register в минуту с одного IP
RATE_LIMIT_AUTH=5
