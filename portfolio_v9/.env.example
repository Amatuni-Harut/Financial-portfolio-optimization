# ============================================================
# AssetAlpha v7 — Пример конфигурации
# Скопируйте этот файл в .env и заполните своими значениями
# НЕ КОММИТЬТЕ .env в git!
# ============================================================

# Строка подключения к PostgreSQL
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DB_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres

# CORS — разрешённые origins (через запятую, без пробелов)
# Для разработки: http://localhost:3000,http://localhost:8000
# Для production: https://yourdomain.com
CORS_ORIGINS=http://localhost:8000

# TTL кэша в часах (по умолчанию 4)
CACHE_TTL_HOURS=4

# Уровень логирования: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
