# ============================================================
# AssetAlpha v13.1 — Шаблон конфигурации
# Скопируйте в .env и заполните своими значениями
# НИКОГДА не коммитьте .env в git!
# ============================================================

# Строка подключения к PostgreSQL (asyncpg)
DB_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/assetalpha

# Секретный ключ JWT (генерация: openssl rand -hex 32)
SECRET_KEY=REPLACE_WITH_STRONG_SECRET_KEY_min32chars

# Время жизни токена в минутах (5 min – 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS origins через запятую
CORS_ORIGINS=http://localhost:8000

# TTL кэша в часах
CACHE_TTL_HOURS=4

# Уровень логирования
LOG_LEVEL=INFO
